{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- session-start",
            "timeout": 20,
            "statusMessage": "Loading OpenClaw-style session guidance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- pre-tool-use",
            "timeout": 20,
            "statusMessage": "Checking OpenClaw-style edit posture"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- post-tool-use",
            "timeout": 180,
            "statusMessage": "Running scoped OpenClaw-style guards"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- pre-compact",
            "timeout": 20,
            "statusMessage": "Preparing OpenClaw-style rehydration note"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- subagent-start",
            "timeout": 20,
            "statusMessage": "Loading OpenClaw-style subagent guidance"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- subagent-stop",
            "timeout": 20,
            "statusMessage": "Checking OpenClaw-style subagent closeout"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- user-prompt-submit",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pnpm codex:hook -- stop",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
