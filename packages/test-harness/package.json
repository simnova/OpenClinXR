{
  "name": "@openclinxr/test-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "openclinxr-bench-mock": "./src/bench-mock.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --root .",
    "bench:mock": "tsx src/bench-mock.ts"
  },
  "dependencies": {
    "@openclinxr/domain": "workspace:*",
    "@openclinxr/review-workflow": "workspace:*",
    "@openclinxr/scenario-fixtures": "workspace:*",
    "@openclinxr/shared-schemas": "workspace:*",
    "@openclinxr/trace-ledger": "workspace:*",
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
