{
  "name": "@openclinxr/graphql",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./documents": "./src/documents.ts",
    "./resolvers": "./src/generated/resolvers.generated.ts"
  },
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "graphql-codegen --config codegen.ts --check",
    "generate": "tsx scripts/generate-static-artifacts.ts && pnpm run codegen",
    "generate:check": "tsx scripts/generate-static-artifacts.ts --check && pnpm run codegen:check",
    "lint": "biome check --no-errors-on-unmatched .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "pnpm run generate:check && vitest run --root ."
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "3.2.0",
    "graphql": "16.12.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/client-preset": "6.0.0",
    "@graphql-codegen/typescript": "6.0.0",
    "@graphql-codegen/typescript-resolvers": "6.0.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
