{
  "name": "@openclinxr/graphql",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./documents": "./src/documents.ts"
  },
  "scripts": {
    "generate": "tsx scripts/generate-static-artifacts.ts",
    "generate:check": "tsx scripts/generate-static-artifacts.ts --check",
