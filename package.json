{
  "name": "openclinxr-agent-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "agent:generate": "tsx tools/agent-factory/generate-agent-scaffold.ts",
    "agent:validate": "tsx tools/agent-factory/validate-artifacts.ts",
    "agent:index": "tsx tools/agent-factory/build-memory-index.ts",
    "agent:score": "tsx tools/agent-factory/score-iteration.ts",
    "agent:compare": "tsx tools/agent-factory/compare-iterations.ts",
    "agent:leadership": "tsx tools/agent-factory/generate-leadership-packet.ts",
    "agent:risks": "tsx tools/agent-factory/find-stale-risks.ts",
    "agent:evidence": "tsx tools/agent-factory/find-evidence-debt.ts",
    "agent:sources": "tsx tools/agent-factory/check-source-ledger.ts",
    "agent:pins": "tsx tools/agent-factory/check-pinned-dependencies.ts",
    "agent:benchmarks": "tsx tools/agent-factory/build-benchmark-gate-report.ts",
    "agent:benchmark-ids": "tsx tools/agent-factory/check-benchmark-gate-evidence-ids.ts",
    "agent:loop": "tsx tools/agent-factory/run-agent-loop.ts",
    "agent:loop:verify": "tsx tools/agent-factory/check-agent-loop-artifacts.ts",
    "agent:maturity": "tsx tools/agent-factory/build-maturity-report.ts",
    "agent:verify": "pnpm agent:validate && pnpm agent:index && pnpm agent:sources && pnpm agent:pins && pnpm agent:loop:verify && pnpm agent:risks && pnpm agent:evidence && pnpm agent:maturity && pnpm agent:benchmarks && pnpm agent:benchmark-ids",
    "packages:typecheck": "TURBO_TELEMETRY_DISABLED=1 DO_NOT_TRACK=1 turbo run typecheck --filter '@openclinxr/*' --filter '@cellix/*'",
    "packages:test": "TURBO_TELEMETRY_DISABLED=1 DO_NOT_TRACK=1 turbo run test --filter '@openclinxr/*' --filter '@cellix/*'",
    "packages:build": "TURBO_TELEMETRY_DISABLED=1 DO_NOT_TRACK=1 turbo run build --filter '@openclinxr/*' --filter '@cellix/*'",
    "packages:typecheck:affected": "TURBO_TELEMETRY_DISABLED=1 DO_NOT_TRACK=1 turbo run typecheck --affected --filter '@openclinxr/*' --filter '@cellix/*'",
    "packages:test:affected": "TURBO_TELEMETRY_DISABLED=1 DO_NOT_TRACK=1 turbo run test --affected --filter '@openclinxr/*' --filter '@cellix/*'",
    "packages:build:affected": "TURBO_TELEMETRY_DISABLED=1 DO_NOT_TRACK=1 turbo run build --affected --filter '@openclinxr/*' --filter '@cellix/*'",
    "typecheck": "tsgo --noEmit && pnpm packages:typecheck",
    "test": "pnpm test:tools && pnpm packages:test",
    "test:tools": "vitest run tools/**/*.test.ts",
    "security:audit": "pnpm audit --audit-level=high",
    "security:audit:prod": "pnpm audit --prod --audit-level=high",
    "security:audit:dev": "pnpm audit --dev --audit-level=high",
    "security:audit-policy": "tsx tools/openclinxr/check-security-audit-policy.ts",
    "security:licenses": "tsx tools/openclinxr/check-license-policy.ts",
    "verify": "pnpm agent:verify && pnpm typecheck && pnpm test && pnpm security:audit && pnpm security:audit-policy && pnpm security:licenses",
    "iwsdk:verify": "pnpm --filter @openclinxr/iwsdk-spike typecheck && pnpm --filter @openclinxr/iwsdk-spike test && pnpm iwsdk:contract:tests && pnpm iwsdk:preinstall && pnpm iwsdk:preinstall:fixture && pnpm iwsdk:workspace:posture -- --approved-sidecar --approved-phase2-devtools --approved-sharp-libvips-exception --approved-uikitml-spatial-text && pnpm iwsdk:evidence:validate && pnpm iwsdk:iwer:evidence -- --input docs/openclinxr/iwer-sidecar-emulation-evidence-2026-05-04.json && pnpm iwer:auto-entry:evidence:validate && pnpm iwer:controller-input:evidence:validate && pnpm --filter @openclinxr/architecture-rules typecheck && pnpm --filter @openclinxr/architecture-rules test && pnpm agent:sources",
    "iwsdk:contract:tests": "vitest run tools/openclinxr/iwsdk-operator-steering-blockers.test.ts tools/openclinxr/iwsdk-ui-xr-parity.test.ts",
    "iwsdk:preinstall": "tsx tools/openclinxr/iwsdk-preinstall-check.ts",
    "iwsdk:preinstall:fixture": "tsx tools/openclinxr/iwsdk-preinstall-check.ts --proposal docs/openclinxr/iwsdk-first-slice-preinstall-proposal.json",
    "iwsdk:workspace:posture": "tsx tools/openclinxr/iwsdk-workspace-posture-check.ts",
    "iwsdk:browser:evidence": "tsx tools/openclinxr/iwsdk-managed-browser-evidence-check.ts",
    "iwsdk:compatibility:evidence": "tsx tools/openclinxr/iwsdk-compatibility-evidence-check.ts",
    "iwsdk:metadata-drift:evidence": "tsx tools/openclinxr/iwsdk-metadata-drift-evidence-check.ts",
    "iwsdk:agent-tooling:evidence": "tsx tools/openclinxr/iwsdk-agent-tooling-evidence-check.ts",
    "iwsdk:iwer:evidence": "tsx tools/openclinxr/iwer-sidecar-emulation-evidence-check.ts",
    "iwer:sidecar:evidence": "tsx tools/openclinxr/iwer-sidecar-emulation-evidence-check.ts --input docs/openclinxr/iwer-sidecar-emulation-evidence-2026-05-04.json",
    "iwer:sidecar:evidence:validate": "tsx tools/openclinxr/iwer-sidecar-emulation-evidence-check.ts --input docs/openclinxr/iwer-sidecar-emulation-evidence-2026-05-04.json",
    "iwer:auto-entry:evidence": "tsx tools/openclinxr/iwer-auto-entry-browser-smoke-check.ts",
    "iwer:auto-entry:evidence:validate": "tsx tools/openclinxr/iwer-auto-entry-browser-smoke-check.ts --input docs/openclinxr/iwer-auto-entry-browser-smoke-frame-lanes-2026-05-05.json",
    "iwer:controller-input:evidence": "tsx tools/openclinxr/iwer-controller-input-probe-check.ts",
    "iwer:controller-input:evidence:validate": "tsx tools/openclinxr/iwer-controller-input-probe-check.ts --input docs/openclinxr/iwer-controller-input-probe-2026-05-05.json",
    "visual:qa:evidence": "tsx tools/openclinxr/visual-qa-evidence-check.ts",
    "visual:qa:evidence:validate": "tsx tools/openclinxr/visual-qa-evidence-check.ts --input docs/openclinxr/visual-qa-evidence-2026-05-04.json",
    "visual:qa:adversarial": "tsx tools/openclinxr/adversarial-visual-qa-evidence.ts",
    "visual:qa:adversarial:validate": "tsx tools/openclinxr/adversarial-visual-qa-evidence.ts --input docs/openclinxr/adversarial-visual-qa-evidence-iwer-sidecar-2026-05-04.json",
    "iwsdk:sidecar:metrics": "tsx tools/openclinxr/iwsdk-sidecar-metrics-check.ts",
    "iwsdk:evidence": "tsx tools/openclinxr/iwsdk-evidence-contract-check.ts",
    "iwsdk:evidence:validate": "tsx tools/openclinxr/iwsdk-evidence-contract-check.ts --validate-latest",
    "bench:mock": "pnpm --filter @openclinxr/test-harness bench:mock",
    "local:runtime:probe": "tsx tools/openclinxr/local-runtime-probe.ts",
    "local:provider:benchmark": "tsx tools/openclinxr/local-provider-benchmark.ts",
    "local:model:runtime": "tsx tools/openclinxr/local-model-runtime-benchmark.ts",
    "local:model:quality": "tsx tools/openclinxr/local-model-quality-benchmark.ts",
    "local:voice:runtime": "tsx tools/openclinxr/local-voice-runtime-benchmark.ts",
    "local:voice:live-dialog": "tsx tools/openclinxr/local-voice-live-dialog-benchmark.ts",
    "local:voice:realtime-spike": "tsx tools/openclinxr/realtime-voice-transport-spike.ts",
    "local:voice:bun-websocket-smoke": "tsx tools/openclinxr/api-bun-websocket-runtime-smoke.ts",
    "local:voice:bun-python-proxy-smoke": "tsx tools/openclinxr/api-bun-python-proxy-runtime-smoke.ts",
    "local:voice:python-backend-smoke": "tsx tools/openclinxr/api-python-backend-runtime-smoke.ts",
    "asset:gltf:smoke": "tsx tools/openclinxr/gltf-pipeline-smoke.ts",
    "asset:blender:bake": "tsx tools/openclinxr/blender-asset-bake-smoke.ts",
    "asset:capability:evidence": "tsx tools/openclinxr/asset-capability-job-evidence.ts",
    "asset:production:readiness": "tsx tools/openclinxr/asset-production-readiness-benchmark.ts",
    "xr:quest:smoke": "tsx tools/openclinxr/quest-cdp-smoke.ts",
    "xr:quest:smoke:validate": "tsx tools/openclinxr/quest-cdp-smoke.ts --validate-latest",
    "xr:quest:manual:harvest": "tsx tools/openclinxr/quest-cdp-smoke.ts --harvest-manual-evidence",
    "xr:quest:manual:check": "tsx tools/openclinxr/check-quest-manual-performance.ts",
    "xr:quest:mr:check": "tsx tools/openclinxr/check-quest-mixed-reality-manual.ts",
    "hygiene:knip": "knip --no-progress --reporter compact --no-exit-code",
    "hygiene:e18e:help": "e18e-cli analyze --help",
    "hygiene:e18e:analyze": "e18e-cli analyze --log-level error"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "fast-glob": "3.3.3",
    "gray-matter": "4.0.3"
  },
  "devDependencies": {
    "@e18e/cli": "0.5.0",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260503.1",
    "archunit": "2.3.0",
    "gltf-pipeline": "4.3.1",
    "knip": "6.11.0",
    "tsx": "4.21.0",
    "turbo": "2.9.8",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "overrides": {
      "three": "0.184.0"
    }
  }
}
