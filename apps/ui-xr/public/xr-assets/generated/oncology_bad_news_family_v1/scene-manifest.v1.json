  "dialogueTurns": [
    {
      "traceTag": "history_opqrst",
      "actorId": "patient_david_miller_v1",
      "text": "David Miller: I know the scan was important, but I am scared to hear what it showed.",
      "gazeTargetKind": "learner_camera",
      "gazeTargetActorId": null
    },
    {
      "traceTag": "risk_factor_question",
      "actorId": "patient_david_miller_v1",
      "text": "David Miller: I want the truth, but please say it in words I can understand.",
      "gazeTargetKind": "learner_camera",
      "gazeTargetActorId": null
    },
    {
      "traceTag": "associated_symptom_question",
      "actorId": "patient_david_miller_v1",
      "text": "David Miller: I have been more tired, and my pain has been harder to ignore.",
      "gazeTargetKind": "learner_camera",
      "gazeTargetActorId": null
    },
    {
      "traceTag": "vitals_review",
      "actorId": "sister_rachel_miller_v1",
      "text": "Rachel Miller: I can help review the available status information.",
      "gazeTargetKind": "learner_camera",
      "gazeTargetActorId": null
    },
    {
      "traceTag": "ecg_request",
      "actorId": "sister_rachel_miller_v1",
      "text": "Rachel Miller: I will help gather the next piece of clinical information.",
      "gazeTargetKind": "learner_camera",
      "gazeTargetActorId": null
    },
    {
      "traceTag": "urgent_escalation",
      "actorId": "sister_rachel_miller_v1",
      "text": "Rachel Miller: Are you saying the cancer has spread? Please do not talk around it.",
      "gazeTargetKind": "learner_camera",
      "gazeTargetActorId": null
    },
    {
      "traceTag": "team_communication",
      "actorId": "sister_rachel_miller_v1",
      "text": "Rachel Miller: I will pause, check understanding, and leave space for questions before next steps.",
      "gazeTargetKind": "actor",
      "gazeTargetActorId": "sister_rachel_miller_v1"
    },
    {
      "traceTag": "family_communication",
      "actorId": "sister_rachel_miller_v1",
      "text": "Rachel Miller: I need you to say what this means for him, but please do it gently.",
      "gazeTargetKind": "actor",
      "gazeTargetActorId": "sister_rachel_miller_v1"
    },
    {
      "traceTag": "empathy_statement",
      "actorId": "patient_david_miller_v1",
      "text": "David Miller: It helps when you acknowledge that this is frightening before explaining the plan.",
      "gazeTargetKind": "learner_camera",
      "gazeTargetActorId": null
    },
    {
      "traceTag": "patient_note_submitted",
