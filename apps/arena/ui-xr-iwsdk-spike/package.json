  "devDependencies": {
    "@iwsdk/vite-plugin-dev": "0.4.2",
    "@iwsdk/vite-plugin-uikitml": "0.4.2",
    "@pmndrs/uikit": "1.0.66",
    "@pmndrs/uikitml": "0.1.12",
    "@types/three": "0.184.0",
    "typescript": "6.0.3",
