{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclinxr.local/schemas/score-history.schema.json",
  "title": "Agent Score History",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "team", "history"],
  "properties": {
    "agent_id": { "type": "string", "minLength": 1 },
    "team": {
      "type": "string",
      "enum": ["coordinator", "core", "physicians", "adversarial", "leadership", "legal"]
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["iteration", "weighted_score", "confidence", "notes"],
        "properties": {
          "iteration": { "type": "integer", "minimum": 0 },
          "weighted_score": { "type": "number", "minimum": 0, "maximum": 5 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
