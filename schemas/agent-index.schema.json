{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclinxr.local/schemas/agent-index.schema.json",
  "title": "Agent Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "team", "last_updated", "entries"],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "team": {
      "type": "string",
      "enum": ["coordinator", "core", "physicians", "adversarial", "leadership", "legal"]
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "topic", "summary", "confidence", "source_ids", "iteration", "status", "supersedes"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["claim", "decision", "risk", "source", "question", "lesson", "capability"]
          },
          "topic": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "iteration": {
            "type": "integer",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": ["active", "superseded", "deferred", "resolved", "rejected"]
          },
          "supersedes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
