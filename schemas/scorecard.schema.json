{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclinxr.local/schemas/scorecard.schema.json",
  "title": "Iteration Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": ["iteration_id", "plan_type", "scored_by", "scored_at", "dimensions", "critical_risks", "evidence_debt", "decision_debt", "confidence", "summary"],
  "properties": {
    "iteration_id": {
      "type": "string",
      "pattern": "^iteration-\\d{4}$"
    },
    "plan_type": {
      "type": "string",
      "enum": ["core-plan", "adversarial-counterplan", "core-revision", "leadership-review"]
    },
    "scored_by": {
      "type": "string",
      "minLength": 1
    },
    "scored_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clinical_validity",
        "psychometric_defensibility",
        "technical_feasibility",
        "architecture_coherence",
        "security_privacy",
        "ux_workflow_fit",
        "cost_performance_efficiency",
        "open_source_sustainability",
        "market_gtm_strength",
        "evidence_discipline",
        "implementation_readiness",
        "adversarial_robustness",
        "legal_regulatory_resilience",
        "specialty_clinical_generalizability"
      ],
      "properties": {
        "clinical_validity": { "$ref": "#/$defs/scoreDimension" },
        "psychometric_defensibility": { "$ref": "#/$defs/scoreDimension" },
        "technical_feasibility": { "$ref": "#/$defs/scoreDimension" },
        "architecture_coherence": { "$ref": "#/$defs/scoreDimension" },
        "security_privacy": { "$ref": "#/$defs/scoreDimension" },
        "ux_workflow_fit": { "$ref": "#/$defs/scoreDimension" },
        "cost_performance_efficiency": { "$ref": "#/$defs/scoreDimension" },
        "open_source_sustainability": { "$ref": "#/$defs/scoreDimension" },
        "market_gtm_strength": { "$ref": "#/$defs/scoreDimension" },
        "evidence_discipline": { "$ref": "#/$defs/scoreDimension" },
        "implementation_readiness": { "$ref": "#/$defs/scoreDimension" },
        "adversarial_robustness": { "$ref": "#/$defs/scoreDimension" },
        "legal_regulatory_resilience": { "$ref": "#/$defs/scoreDimension" },
        "specialty_clinical_generalizability": { "$ref": "#/$defs/scoreDimension" }
      }
    },
    "critical_risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "evidence_debt": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/debt"
      }
    },
    "decision_debt": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/debt"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "scoreDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "rationale"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "summary", "owner", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "summary": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "mitigated", "accepted", "deferred"] }
      }
    },
    "debt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "owner", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "resolved", "deferred"] }
      }
    }
  }
}
