{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclinxr.local/schemas/source-record.schema.json",
  "title": "Source Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["source_id", "title", "source_type", "citation", "accessed_at", "permitted_uses", "claims_supported", "claims_not_supported", "confidence"],
  "properties": {
    "source_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "url": { "type": "string" },
    "file_path": { "type": "string" },
    "source_type": {
      "type": "string",
      "enum": ["authoritative-standard", "regulator", "peer-reviewed", "professional-guidance", "market-research", "financial-media", "vendor", "internal-artifact", "legal-context", "clinical-guideline"]
    },
    "citation": { "type": "string", "minLength": 1 },
    "accessed_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "permitted_uses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "claims_supported": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claims_not_supported": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "anyOf": [
    { "required": ["url"] },
    { "required": ["file_path"] }
  ]
}
