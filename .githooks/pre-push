#!/usr/bin/env sh
set -eu

if [ "${OPENCLAW_SKIP_HOOKS:-}" = "1" ]; then
  echo "OPENCLAW_SKIP_HOOKS=1 set; skipping pre-push hook."
  exit 0
fi

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck disable=SC1090
  . "$NVM_DIR/nvm.sh"
  nvm use >/dev/null
fi

echo "Running OpenClaw pre-push guardrails..."
pnpm hooks:pre-push
