# OpenClinXR local AI benchmark configuration.
# Copy values into your local shell or private env file after installing the runtime.
# Example usage: pnpm local:provider:benchmark -- --env-file .env.openclinxr.local
# No cloud calls, model downloads, or runtime execution are performed by pnpm local:provider:benchmark.

# Supported runtime commands detected by the current local probe: ollama, llama-cli, llama-server, mlx_lm.
OPENCLINXR_LOCAL_MODEL_RUNTIME=

# Source-backed example values after local install approval only:
# - Qwen/Qwen3-4B-GGUF maps to src-qwen3-4b-gguf-2026.
# - deepseek-ai/DeepSeek-R1-Distill-Qwen-7B maps to src-deepseek-r1-distill-qwen-2025.
OPENCLINXR_LOCAL_MODEL_ID=

# Set to true only after Patrick approves the model source, license posture, disk size, and download.
OPENCLINXR_LOCAL_MODEL_DOWNLOAD_APPROVED=false

# Current local probe expects a VibeVoice-compatible command named vibevoice.
OPENCLINXR_LOCAL_VOICE_RUNTIME=

# Source-backed example after local install approval only:
# - microsoft/VibeVoice-Realtime-0.5B maps to src-vibevoice-github-2026.
OPENCLINXR_LOCAL_VOICE_ID=

# Set to true only after Patrick approves the install path, disk footprint, model source, and uninstall command.
OPENCLINXR_LOCAL_VOICE_INSTALL_APPROVED=false

# Set to true only after Patrick approves the VibeVoice safety/license posture and first-audio benchmark scope.
OPENCLINXR_LOCAL_VOICE_SAFETY_REVIEW_APPROVED=false

# Optional local realtime voice gateway proxy.
# Set only when apps/api-python-backend is already running locally.
# Example: ws://127.0.0.1:8765/voice/realtime/ws
OPENCLINXR_PYTHON_VOICE_BACKEND_WS_URL=

# Optional passed local proxy evidence file used only to annotate /voice/realtime/posture.
# This must point at an existing no-cloud local smoke report and does not make live dialog ready.
# Example: docs/openclinxr/api-bun-python-proxy-runtime-smoke-2026-05-05.json
OPENCLINXR_PYTHON_VOICE_PROXY_EVIDENCE_FILE=
